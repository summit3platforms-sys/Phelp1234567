generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Brand {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  articles    Article[]
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  articles    Article[]
}

model Article {
  id                   String    @id @default(uuid())
  title                String
  slug                 String    @unique
  content              String
  featuredImage        String?
  featuredImageAlt     String?
  featuredImageTitle   String?
  featuredImageCaption String?
  errorCode            String?
  printerModel         String?
  tags                 String?
  seoTitle             String?
  metaDescription      String?
  canonicalUrl         String?
  wordCount            Int?
  excerpt              String?
  featuredSnippet      String?
  faqs                 String?   // JSON string representing FAQs: [{question, answer, order}]
  status               String    @default("draft")
  uploadedImages       String?   // JSON string representing uploaded images list: [{id, src, name, alt, caption}]
  brandId              String?
  categoryId           String?
  publishedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  authorId             String?
  author               Author?   @relation(fields: [authorId], references: [id])
  brand                Brand?    @relation(fields: [brandId], references: [id])
  category             Category? @relation(fields: [categoryId], references: [id])
  revisions            Revision[]
}

model Revision {
  id                   String   @id @default(uuid())
  articleId            String
  article              Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  version              Int
  title                String
  content              String
  seoTitle             String?
  metaDescription      String?
  faqs                 String?
  featuredImage        String?
  featuredImageAlt     String?
  featuredImageTitle   String?
  featuredImageCaption String?
  excerpt              String?
  featuredSnippet      String?
  uploadedImages       String?
  createdAt            DateTime @default(now())
}

model Redirect {
  id        String   @id @default(uuid())
  oldUrl    String   @unique
  newUrl    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id           String   @id @default(uuid())
  name         String
  email        String
  phone        String
  printerBrand String
  status       String   @default("new")
  createdAt    DateTime @default(now())
}

model Author {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  bio       String?
  image     String?
  role      String?   @default("Technical Expert")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  articles  Article[]
}

